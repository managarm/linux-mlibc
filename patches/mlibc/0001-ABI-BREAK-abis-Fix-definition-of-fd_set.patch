From 559ea0b89d4fe5062e6c3b3023dab1586090fb2a Mon Sep 17 00:00:00 2001
From: Dennis Bonke <admin@dennisbonke.com>
Date: Sun, 11 Jan 2026 22:07:40 +0100
Subject: [PATCH] [ABI BREAK]: abis: Fix definition of fd_set

---
 ABI_BREAKS.md                        |  1 +
 abis/ironclad/fd_set.h               |  5 ++++-
 abis/linux/fd_set.h                  | 15 +++++++++++++--
 options/posix/generic/sys-select.cpp | 14 +++++++++++---
 options/posix/include/sys/select.h   |  3 ---
 5 files changed, 29 insertions(+), 9 deletions(-)

diff --git a/ABI_BREAKS.md b/ABI_BREAKS.md
index 81999a6f..53785d71 100644
--- a/ABI_BREAKS.md
+++ b/ABI_BREAKS.md
@@ -27,6 +27,7 @@ This document lists the ABI breaks that were made in each mlibc major version.
 - [#1460](https://github.com/managarm/mlibc/pull/1460): `useconds_t` was turned into a 32-bit value, as it only needs to hold microsecond values worth up to a second.
 - [#1492](https://github.com/managarm/mlibc/pull/1492): changes the values of `LC_*` macros and `nl_item` values to match glibc, so that glibc locale files can be consumed.
 - [#1492](https://github.com/managarm/mlibc/pull/1492): fix `struct epoll_event` alignment on x86
+- [#1658](https://github.com/managarm/mlibc/pull/1658): fix incorrect definition of `struct fd_set`
 
 ## Version 6
 
diff --git a/abis/ironclad/fd_set.h b/abis/ironclad/fd_set.h
index 380a56ca..a2a0285c 100644
--- a/abis/ironclad/fd_set.h
+++ b/abis/ironclad/fd_set.h
@@ -5,8 +5,11 @@
 
 #define FD_SETSIZE 1024
 
+typedef __mlibc_uint8 __fd_mask;
+#define __NFDBITS (8 * (int) sizeof (__fd_mask))
+
 typedef struct __attribute__((__aligned__(__alignof__(long)))) {
-	__mlibc_uint8 fds_bits[128];
+	__fd_mask fds_bits[FD_SETSIZE / __NFDBITS];
 } fd_set;
 
 #endif /* _ABIBITS_FD_SET_H */
diff --git a/abis/linux/fd_set.h b/abis/linux/fd_set.h
index 380a56ca..3b18edbb 100644
--- a/abis/linux/fd_set.h
+++ b/abis/linux/fd_set.h
@@ -1,12 +1,23 @@
 #ifndef _ABIBITS_FD_SET_H
 #define _ABIBITS_FD_SET_H
 
+#include <mlibc-config.h>
+
 #include <bits/types.h>
 
 #define FD_SETSIZE 1024
 
-typedef struct __attribute__((__aligned__(__alignof__(long)))) {
-	__mlibc_uint8 fds_bits[128];
+typedef long int __fd_mask;
+#define __NFDBITS (8 * (int) sizeof (__fd_mask))
+
+typedef struct {
+	/* libtirpc reaches into fds_bits directly, so we must keep the name and type exactly as expected.
+	 * This now matches the definition in sys/select.h from glibc. */
+#if __MLIBC_XOPEN
+	__fd_mask fds_bits[FD_SETSIZE / __NFDBITS];
+#else
+	__fd_mask __fds_bits[FD_SETSIZE / __NFDBITS];
+#endif
 } fd_set;
 
 #endif /* _ABIBITS_FD_SET_H */
diff --git a/options/posix/generic/sys-select.cpp b/options/posix/generic/sys-select.cpp
index f0c3fb1b..1429bfa0 100644
--- a/options/posix/generic/sys-select.cpp
+++ b/options/posix/generic/sys-select.cpp
@@ -1,3 +1,5 @@
+#include <bit>
+#include <type_traits>
 
 #include <string.h>
 #include <sys/select.h>
@@ -9,17 +11,23 @@
 
 #include <mlibc/posix-sysdeps.hpp>
 
+using fd_mask_unsigned = std::make_unsigned_t<__fd_mask>;
+
+static_assert(std::has_single_bit((unsigned int)NFDBITS));
+
+#define FD_MASK(n) (fd_mask_unsigned)(fd_mask_unsigned{1} << (n))
+
 void __FD_CLR(int fd, fd_set *set) {
 	__ensure(fd < FD_SETSIZE);
-	set->fds_bits[fd / 8] &= ~(1 << (fd % 8));
+	set->fds_bits[fd / NFDBITS] &= std::bit_cast<fd_mask>(~FD_MASK(fd & (NFDBITS-1)));
 }
 int __FD_ISSET(int fd, fd_set *set) {
 	__ensure(fd < FD_SETSIZE);
-	return set->fds_bits[fd / 8] & (1 << (fd % 8));
+	return (std::bit_cast<fd_mask_unsigned>(set->fds_bits[fd / NFDBITS]) & FD_MASK(fd & (NFDBITS-1))) != 0;
 }
 void __FD_SET(int fd, fd_set *set) {
 	__ensure(fd < FD_SETSIZE);
-	set->fds_bits[fd / 8] |= 1 << (fd % 8);
+	set->fds_bits[fd / NFDBITS] = std::bit_cast<fd_mask>(std::bit_cast<fd_mask_unsigned>(set->fds_bits[fd / NFDBITS]) | FD_MASK(fd & (NFDBITS-1)));
 }
 void __FD_ZERO(fd_set *set) {
 	memset(set->fds_bits, 0, sizeof(fd_set));
diff --git a/options/posix/include/sys/select.h b/options/posix/include/sys/select.h
index 3c15ab01..bd3f86cc 100644
--- a/options/posix/include/sys/select.h
+++ b/options/posix/include/sys/select.h
@@ -14,9 +14,6 @@
 extern "C" {
 #endif
 
-typedef long int __fd_mask;
-#define __NFDBITS (8 * (int) sizeof (__fd_mask))
-
 #if defined(_DEFAULT_SOURCE)
 typedef __fd_mask fd_mask;
 #define NFDBITS __NFDBITS
-- 
2.53.0

